generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String            @id @default(uuid())
  email                  String            @unique
  name                   String            @unique
  role                   Role              @default(PLAYER)
  createdAt              DateTime          @default(now())
  password               String
  matchScores            MatchScore[]
  pickHistoriesSubmitted PickHistory[]     @relation("SubmittedHistory")
  PickHistory            PickHistory[]
  picksSubmitted         PlayerPick[]      @relation("SubmittedByRelation")
  picks                  PlayerPick[]      @relation("UserPicks")
  seasonPrediction       SeasonPrediction?
}

model Team {
  name           String
  captain        String
  shortName      String   @unique
  id             Int      @id @default(autoincrement())
  matchesAsTeamA Match[]  @relation("TeamA")
  matchesAsTeamB Match[]  @relation("TeamB")
  players        Player[]
}

/// ///////////////////
/// //////////////////
model Player {
  name          String
  id            Int    @id @default(autoincrement())
  teamShortName String
  team          Team   @relation(fields: [teamShortName], references: [shortName])
}

model Match {
  id             String        @id @default(uuid())
  matchNo        Int
  date           DateTime
  venue          String
  scheduledStart DateTime
  actualStart    DateTime?
  manOfMatch1    String?
  manOfMatch2    String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @default(dbgenerated("(now() AT TIME ZONE 'utc'::text)")) @updatedAt
  status         MatchStatus   @default(SCHEDULED)
  teamAShortName String
  teamBShortName String
  manOfMatch     String?
  winningTeamId  String?
  teamA          Team          @relation("TeamA", fields: [teamAShortName], references: [shortName])
  teamB          Team          @relation("TeamB", fields: [teamBShortName], references: [shortName])
  scores         MatchScore[]
  PickHistory    PickHistory[]
  picks          PlayerPick[]
}

model PlayerPick {
  id             String        @id @default(uuid())
  userId         String
  matchId        String
  teamPickedId   String
  mom1Picked     String?
  mom2Picked     String?
  lastModifiedAt DateTime?
  approvalTime   DateTime?
  approvedBy     String?
  createdAt      DateTime      @default(now())
  submittedBy    String
  status         PickStatus    @default(PENDING)
  submittedAt    DateTime?     @db.Timestamp(6)
  history        PickHistory[]
  match          Match         @relation(fields: [matchId], references: [id])
  submittedUser  User          @relation("SubmittedByRelation", fields: [submittedBy], references: [id])
  user           User          @relation("UserPicks", fields: [userId], references: [id])

  @@unique([userId, matchId])
}

model PickHistory {
  id            String      @id @default(dbgenerated("gen_random_uuid()"))
  teamPickedId  String
  playerPickId  String?
  mom1Picked    String?
  mom2Picked    String?
  modifiedAt    DateTime    @default(now())
  matchId       String
  status        PickStatus  @default(PENDING)
  submittedBy   String
  userId        String
  match         Match       @relation(fields: [matchId], references: [id])
  pick          PlayerPick? @relation(fields: [playerPickId], references: [id])
  submittedUser User        @relation("SubmittedHistory", fields: [submittedBy], references: [id])
  user          User        @relation(fields: [userId], references: [id])
}

/// ////////////////////
/// ////////////////////
model SeasonPrediction {
  id             String                    @id @default(uuid())
  userId         String                    @unique
  submittedBy    String
  top1TeamId     String
  top2TeamId     String
  top3TeamId     String
  top4TeamId     String
  bottom1TeamId  String
  bottom2TeamId  String
  orangeCap1     String
  orangeCap2     String
  orangeCap3     String
  purpleCap1     String
  purpleCap2     String
  purpleCap3     String
  submittedAt    DateTime                  @default(now())
  lastModifiedAt DateTime?
  user           User                      @relation(fields: [userId], references: [id])
  history        SeasonPredictionHistory[]
}

model SeasonPredictionHistory {
  id                 String           @id @default(uuid())
  seasonPredictionId String
  top1TeamId         String
  top2TeamId         String
  top3TeamId         String
  top4TeamId         String
  bottom1TeamId      String
  bottom2TeamId      String
  orangeCap1         String
  orangeCap2         String
  orangeCap3         String
  purpleCap1         String
  purpleCap2         String
  purpleCap3         String
  modifiedBy         String
  modifiedAt         DateTime         @default(now())
  prediction         SeasonPrediction @relation(fields: [seasonPredictionId], references: [id])
}

model MatchScore {
  id           String   @id @default(uuid())
  userId       String
  matchId      String
  result       String
  streak       Int
  points       Int
  isMomCorrect Boolean
  createdAt    DateTime @default(now())
  match        Match    @relation(fields: [matchId], references: [id])
  user         User     @relation(fields: [userId], references: [id])

  @@unique([userId, matchId])
}

enum Role {
  ADMIN
  PLAYER
}

enum MatchStatus {
  SCHEDULED
  STARTED
  DELAYED
  CANCELLED
  COMPLETED
}

enum PickStatus {
  PENDING
  MODIFIED_PENDING
  APPROVED
  REJECTED
}
